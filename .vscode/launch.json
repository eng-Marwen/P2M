{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/index.ts"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/backend",
      "skipFiles": ["<node_internals>/**", "node_modules/**"],
      "internalConsoleOptions": "neverOpen",
      "outputCapture": "std"
    },
    {
      "name": "FastAPI Debug",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/aimicroservice/aivenv/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/aimicroservice",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/aimicroservice/.env",
      "console": "integratedTerminal",
      "justMyCode": true,
      "jinja": true
    }
  ]
}
